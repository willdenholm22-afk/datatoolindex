---
import fs from 'fs';
import path from 'path';
import { marked } from 'marked';

export async function getStaticPaths() {
  const dir = path.join(process.cwd(), 'src/content/use-cases');
  const files = fs.readdirSync(dir).filter(f => f.endsWith('.mdx'));
  return files.map(file => ({
    params: { slug: file.replace('.mdx', '') },
    props: { file }
  }));
}

const { file } = Astro.props;
const slug = Astro.params.slug;

let content = '';
let title = slug;
let description = '';
let lastVerified = '';

try {
  const filePath = path.join(process.cwd(), `src/content/use-cases/${file}`);
  const raw = fs.readFileSync(filePath, 'utf-8');

  const innerMatch = raw.match(/```mdx\n([\s\S]*?)```\s*$/);
  if (innerMatch) {
    const inner = innerMatch[1];
    const metaMatch = inner.match(/^---\n([\s\S]*?)\n---/);
    if (metaMatch) {
      const meta = metaMatch[1];
      const vMatch = meta.match(/last[Vv]erified:\s*"?([0-9-]+)"?/);
      if (vMatch) lastVerified = vMatch[1];
      const pvMatch = meta.match(/publishDate:\s*([0-9-]+)/);
      if (!lastVerified && pvMatch) lastVerified = pvMatch[1];
      const dMatch = meta.match(/description:\s*"([^"]+)"/);
      if (dMatch) description = dMatch[1];
    }
    // Strip inner frontmatter and fix author attribution
    let stripped = inner.replace(/^---[\s\S]*?---\n/, '');
    // Remove the "Comparison Hub" author block if present
    stripped = stripped.replace(/## Author[\s\S]*?Last verified:[^\n]*\n?/g, '');
    content = stripped;
  } else {
    const lines = raw.split('\n');
    let inFm = false, pastFm = false;
    const out = [];
    for (const line of lines) {
      if (line.trim() === '---') {
        if (!inFm && !pastFm) { inFm = true; continue; }
        if (inFm) { inFm = false; pastFm = true; continue; }
      }
      if (pastFm && !line.startsWith('```')) out.push(line);
    }
    content = out.join('\n');
  }

  const tMatch = content.match(/^#\s+(.+)$/m);
  if (tMatch) title = tMatch[1];
  if (!description) {
    const sentences = content.replace(/^#.*$/mg, '').trim().split('\n').filter(l => l.trim().length > 40);
    if (sentences[0]) description = sentences[0].replace(/\*\*/g, '').substring(0, 160);
  }
} catch (e) {
  content = `# Error\n\nCould not load ${slug}.`;
}

const renderer = new marked.Renderer();
renderer.link = ({ href, title: t, text }) => {
  const isExternal = href && (href.startsWith('http://') || href.startsWith('https://'));
  const isCTA = text && (text.includes('→') || text.startsWith('Visit ') || text.startsWith('Try '));
  const attrs = isExternal ? ' target="_blank" rel="noopener noreferrer"' : '';
  const cls = isCTA ? ' class="cta-link"' : (isExternal ? ' class="ext-link"' : '');
  const titleAttr = t ? ` title="${t}"` : '';
  return `<a href="${href}"${attrs}${cls}${titleAttr}>${text}</a>`;
};

const html = marked.parse(content, { renderer });

const canonicalURL = `https://datatoolindex.com/use-cases/${slug}/`;
const verifiedDisplay = lastVerified
  ? new Date(lastVerified).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
  : 'Apr 2026';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} | DataToolIndex</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="sitemap" href="/sitemap-index.xml" />

  <meta property="og:type" content="article" />
  <meta property="og:title" content={`${title} | DataToolIndex`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="DataToolIndex" />

  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #FAFAF9;
      --bg-alt: #F3F1ED;
      --border: #E0DBD3;
      --text: #1A1917;
      --text-2: #6B6760;
      --text-3: #9C9790;
      --green: #1B5E3B;
      --green-bg: #EEF7F2;
      --green-border: #86C9A4;
      --amber: #78350F;
      --amber-bg: #FFFBEB;
      --amber-border: #F59E0B;
      --mono: 'IBM Plex Mono', 'Courier New', monospace;
      --serif: 'Playfair Display', Georgia, serif;
      --sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
      --max-w: 720px;
    }

    html { background: var(--bg); color: var(--text); font-family: var(--sans); font-size: 16px; line-height: 1.75; -webkit-font-smoothing: antialiased; }

    .site-header { border-bottom: 1px solid var(--border); padding: 14px 20px; display: flex; align-items: center; justify-content: space-between; }
    .site-logo { font-family: var(--mono); font-size: 13px; font-weight: 500; letter-spacing: 0.04em; text-decoration: none; color: var(--text); }
    .site-logo span { color: var(--green); }
    .site-nav { display: flex; gap: 20px; }
    .site-nav a { font-size: 13px; color: var(--text-2); text-decoration: none; }
    .site-nav a:hover { color: var(--text); }

    .breadcrumb { max-width: var(--max-w); margin: 0 auto; padding: 16px 20px 0; font-family: var(--mono); font-size: 11px; color: var(--text-3); letter-spacing: 0.03em; }
    .breadcrumb a { color: var(--text-3); text-decoration: none; }
    .breadcrumb a:hover { color: var(--green); }
    .breadcrumb span { margin: 0 6px; }

    .page { max-width: var(--max-w); margin: 0 auto; padding: 0 20px 80px; }

    /* Use-case pages get a blue-tinted accent instead of pure green to differentiate */
    .article-header { padding: 28px 0 32px; border-bottom: 1px solid var(--border); margin-bottom: 36px; }
    .use-case-label {
      display: inline-block;
      font-family: var(--mono);
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--green);
      background: var(--green-bg);
      border: 1px solid var(--green-border);
      padding: 3px 8px;
      border-radius: 3px;
      margin-bottom: 12px;
    }
    .article-header h1 { font-family: var(--serif); font-size: clamp(1.5rem, 4vw, 2rem); line-height: 1.25; letter-spacing: -0.01em; color: var(--text); margin: 0 0 16px; }
    .article-meta { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; font-family: var(--mono); font-size: 12px; color: var(--text-2); }
    .meta-author { color: var(--text); font-weight: 500; }
    .meta-verified { display: inline-flex; align-items: center; gap: 5px; background: var(--green-bg); color: var(--green); border: 1px solid var(--green-border); padding: 2px 8px; border-radius: 3px; font-size: 11px; }
    .meta-verified::before { content: '✓'; font-weight: 700; }

    article { font-size: 16px; line-height: 1.8; }
    article > p:first-of-type { font-size: 17px; line-height: 1.7; border-left: 3px solid var(--green); padding-left: 16px; margin-bottom: 28px; }
    article h2 { font-family: var(--sans); font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-3); margin: 40px 0 14px; padding-bottom: 8px; border-bottom: 1px solid var(--border); }
    article h3 { font-family: var(--sans); font-size: 15px; font-weight: 700; color: var(--text); margin: 24px 0 8px; }
    article h3 + p { margin-top: 0; }
    article p { margin: 0 0 16px; }
    article ul, article ol { margin: 0 0 16px 20px; }
    article li { margin-bottom: 6px; }
    article strong { font-weight: 700; }
    article code { font-family: var(--mono); font-size: 13px; background: var(--bg-alt); border: 1px solid var(--border); padding: 1px 5px; border-radius: 3px; }

    article table { width: 100%; border-collapse: collapse; font-size: 14px; margin: 20px 0 28px; border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
    article thead { background: var(--text); color: #fff; }
    article th { font-family: var(--mono); font-size: 11px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; padding: 10px 14px; text-align: left; }
    article td { padding: 10px 14px; border-bottom: 1px solid var(--border); vertical-align: top; }
    article tr:last-child td { border-bottom: none; }
    article tbody tr:nth-child(even) { background: var(--bg-alt); }

    article a { color: var(--green); text-decoration: underline; text-underline-offset: 2px; }
    article a:hover { text-decoration: none; }
    article a.ext-link::after { content: ' ↗'; font-size: 11px; opacity: 0.6; }
    article a.cta-link { display: inline-block; background: var(--green); color: #fff !important; text-decoration: none !important; padding: 6px 14px; border-radius: 4px; font-size: 14px; font-weight: 500; margin: 4px 0; transition: background 0.15s; }
    article a.cta-link:hover { background: #145030; }
    article a.cta-link::after { content: none !important; }

    .section-callout { border-radius: 6px; padding: 18px 20px; margin: 0 0 28px; }
    .section-callout--green { background: var(--green-bg); border: 1px solid var(--green-border); }
    .section-callout--green li::marker { color: var(--green); }
    .section-callout--amber { background: var(--amber-bg); border: 1px solid var(--amber-border); }
    .section-callout--amber li::marker { color: var(--amber); }
    .section-callout--verdict { background: var(--text); color: #fff; padding: 24px 28px; }
    .section-callout--verdict p { color: rgba(255,255,255,0.9); margin-bottom: 12px; }
    .section-callout--verdict p:last-child { margin-bottom: 0; }
    .section-callout--verdict a { color: #86C9A4; }
    .section-callout--verdict strong { color: #fff; }

    /* Ranked shortlist items */
    article h3 { counter-increment: none; }
    .ranked-item { border: 1px solid var(--border); border-radius: 6px; padding: 20px; margin-bottom: 16px; }
    .ranked-item h3 { margin: 0 0 12px; font-size: 16px; }

    .page-footer { max-width: var(--max-w); margin: 48px auto 0; padding: 28px 20px; border-top: 1px solid var(--border); }
    .author-block { display: flex; gap: 16px; align-items: flex-start; margin-bottom: 20px; }
    .author-avatar { width: 40px; height: 40px; border-radius: 50%; background: var(--text); color: #fff; display: flex; align-items: center; justify-content: center; font-family: var(--mono); font-size: 14px; font-weight: 500; flex-shrink: 0; }
    .author-info { font-size: 13px; line-height: 1.5; }
    .author-name { font-weight: 700; color: var(--text); display: block; margin-bottom: 2px; }
    .author-bio { color: var(--text-2); }
    .disclosure { font-size: 12px; color: var(--text-3); padding: 14px; background: var(--bg-alt); border-radius: 4px; border: 1px solid var(--border); }

    @media (max-width: 600px) {
      .site-nav { display: none; }
      .article-header h1 { font-size: 1.4rem; }
      article table { font-size: 13px; }
      article th, article td { padding: 8px 10px; }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <a href="/" class="site-logo">Data<span>Tool</span>Index</a>
    <nav class="site-nav">
      <a href="/">All Tools</a>
      <a href="/methodology/">Methodology</a>
    </nav>
  </header>

  <div class="breadcrumb">
    <a href="/">DataToolIndex</a>
    <span>/</span>
    <a href="/">Use Cases</a>
    <span>/</span>
    {title}
  </div>

  <div class="page">
    <header class="article-header">
      <div class="use-case-label">Buyer's Guide</div>
      <h1>{title}</h1>
      <div class="article-meta">
        <span class="meta-author">Will Denholm</span>
        <span>·</span>
        <span>Pricing Analyst, 7+ yrs</span>
        <span>·</span>
        <span class="meta-verified">Verified {verifiedDisplay}</span>
      </div>
    </header>

    <article set:html={html} />
  </div>

  <footer class="page-footer">
    <div class="author-block">
      <div class="author-avatar">WD</div>
      <div class="author-info">
        <span class="author-name">Will Denholm</span>
        <span class="author-bio">7+ years as a B2B industrial pricing analyst. Built pricing variance models and evaluated enterprise data tools in production. All recommendations reflect direct practitioner experience.</span>
      </div>
    </div>
    <div class="disclosure">
      Some links on this page are affiliate links — we may earn a commission at no cost to you. This does not affect rankings. <a href="/methodology/">Our methodology is public.</a>
    </div>
  </footer>

  <script>
    (function() {
      const article = document.querySelector('article');
      if (!article) return;

      function getCalloutClass(text) {
        const t = text.toLowerCase();
        if (t.includes('best for') || t.includes('when to choose') || t.includes('who should')) return 'section-callout--green';
        if (t.includes('avoid') || t.includes('what to avoid') || t.includes('not ideal') || t.includes('runner')) return 'section-callout--amber';
        if (t === 'verdict' || t.includes('bottom line') || t.includes('our recommendation')) return 'section-callout--verdict';
        return null;
      }

      Array.from(article.querySelectorAll('h2')).forEach(h2 => {
        const cls = getCalloutClass(h2.textContent.trim());
        if (!cls) return;
        const box = document.createElement('div');
        box.className = 'section-callout ' + cls;
        const siblings = [];
        let next = h2.nextElementSibling;
        while (next && next.tagName !== 'H2') { siblings.push(next); next = next.nextElementSibling; }
        if (!siblings.length) return;
        h2.after(box);
        siblings.forEach(s => box.appendChild(s));
      });

      // Standalone paragraph links → CTA
      article.querySelectorAll('a[href^="http"]').forEach(a => {
        if (!a.classList.contains('cta-link') && !a.closest('table')) {
          const parent = a.parentElement;
          if (parent && parent.tagName === 'P' && parent.textContent.trim() === a.textContent.trim()) {
            a.classList.add('cta-link');
          }
        }
      });
    })();
  </script>
</body>
</html>
