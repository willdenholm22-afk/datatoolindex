<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} | DataToolIndex</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- Open Graph -->
  <meta property="og:type" content="article" />
  <meta property="og:title" content={`${title} | DataToolIndex`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="DataToolIndex" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #FAFAF9;
      --bg-alt: #F3F1ED;
      --border: #E0DBD3;
      --text: #1A1917;
      --text-2: #6B6760;
      --text-3: #9C9790;
      --green: #1B5E3B;
      --green-bg: #EEF7F2;
      --green-border: #86C9A4;
      --amber: #78350F;
      --amber-bg: #FFFBEB;
      --amber-border: #F59E0B;
      --red: #7F1D1D;
      --red-bg: #FEF2F2;
      --mono: 'IBM Plex Mono', 'Courier New', monospace;
      --serif: 'Playfair Display', Georgia, serif;
      --sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
      --max-w: 720px;
    }

    html { background: var(--bg); color: var(--text); font-family: var(--sans); font-size: 16px; line-height: 1.75; -webkit-font-smoothing: antialiased; }
    body { min-height: 100vh; }

    /* ── Header ── */
    .site-header {
      border-bottom: 1px solid var(--border);
      padding: 14px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .site-logo {
      font-family: var(--mono);
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.04em;
      text-decoration: none;
      color: var(--text);
    }
    .site-logo span { color: var(--green); }
    .site-nav { display: flex; gap: 20px; }
    .site-nav a { font-size: 13px; color: var(--text-2); text-decoration: none; }
    .site-nav a:hover { color: var(--text); }

    /* ── Breadcrumb ── */
    .breadcrumb {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 16px 20px 0;
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text-3);
      letter-spacing: 0.03em;
    }
    .breadcrumb a { color: var(--text-3); text-decoration: none; }
    .breadcrumb a:hover { color: var(--green); }
    .breadcrumb span { margin: 0 6px; }

    /* ── Page wrapper ── */
    .page { max-width: var(--max-w); margin: 0 auto; padding: 0 20px 80px; }

    /* ── Article header ── */
    .article-header { padding: 28px 0 32px; border-bottom: 1px solid var(--border); margin-bottom: 36px; }
    .article-header h1 {
      font-family: var(--serif);
      font-size: clamp(1.6rem, 4vw, 2.2rem);
      line-height: 1.25;
      letter-spacing: -0.01em;
      color: var(--text);
      margin: 12px 0 16px;
    }
    .article-meta {
      display: flex;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
      font-family: var(--mono);
      font-size: 12px;
      color: var(--text-2);
    }
    .meta-author { color: var(--text); font-weight: 500; }
    .meta-verified {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      background: var(--green-bg);
      color: var(--green);
      border: 1px solid var(--green-border);
      padding: 2px 8px;
      border-radius: 3px;
      font-size: 11px;
    }
    .meta-verified::before { content: '✓'; font-weight: 700; }

    /* ── Article body ── */
    article { font-size: 16px; line-height: 1.8; color: var(--text); }

    article > p:first-of-type {
      font-size: 17px;
      line-height: 1.7;
      color: var(--text);
      border-left: 3px solid var(--green);
      padding-left: 16px;
      margin-bottom: 28px;
    }

    article h2 {
      font-family: var(--sans);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-3);
      margin: 40px 0 14px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--border);
    }
    article h3 {
      font-family: var(--sans);
      font-size: 15px;
      font-weight: 700;
      color: var(--text);
      margin: 24px 0 8px;
    }

    article p { margin: 0 0 16px; }
    article ul, article ol { margin: 0 0 16px 20px; }
    article li { margin-bottom: 6px; }
    article li p { margin: 0; }

    article strong { font-weight: 700; color: var(--text); }
    article em { font-style: italic; }
    article code {
      font-family: var(--mono);
      font-size: 13px;
      background: var(--bg-alt);
      border: 1px solid var(--border);
      padding: 1px 5px;
      border-radius: 3px;
    }

    /* ── Tables ── */
    article table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
      margin: 20px 0 28px;
      border: 1px solid var(--border);
      border-radius: 6px;
      overflow: hidden;
    }
    article thead { background: var(--text); color: #fff; }
    article th {
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 10px 14px;
      text-align: left;
    }
    article td {
      padding: 10px 14px;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }
    article tr:last-child td { border-bottom: none; }
    article tbody tr:nth-child(even) { background: var(--bg-alt); }
    /* Highlight price cells (2nd column typically) */
    article td:nth-child(2) {
      font-family: var(--mono);
      font-size: 13px;
      font-weight: 500;
      color: var(--green);
    }

    /* ── Links ── */
    article a { color: var(--green); text-decoration: underline; text-underline-offset: 2px; }
    article a:hover { text-decoration: none; }
    article a.ext-link::after { content: ' ↗'; font-size: 11px; opacity: 0.6; }

    /* CTA links (Visit X →, Try X →) */
    article a.cta-link {
      display: inline-block;
      background: var(--green);
      color: #fff !important;
      text-decoration: none !important;
      padding: 6px 14px;
      border-radius: 4px;
      font-size: 14px;
      font-weight: 500;
      margin: 4px 0;
      transition: background 0.15s;
    }
    article a.cta-link:hover { background: #145030; }
    article a.cta-link::after { content: none !important; }

    /* ── Callout boxes (added via JS) ── */
    .section-callout {
      border-radius: 6px;
      padding: 18px 20px;
      margin: 0 0 28px;
    }
    .section-callout--green {
      background: var(--green-bg);
      border: 1px solid var(--green-border);
    }
    .section-callout--green li::marker { color: var(--green); }
    .section-callout--amber {
      background: var(--amber-bg);
      border: 1px solid var(--amber-border);
    }
    .section-callout--amber li::marker { color: var(--amber); }
    .section-callout--verdict {
      background: var(--text);
      color: #fff;
      border: none;
      padding: 24px 28px;
    }
    .section-callout--verdict p { color: rgba(255,255,255,0.9); margin-bottom: 12px; }
    .section-callout--verdict p:last-child { margin-bottom: 0; }
    .section-callout--verdict a { color: #86C9A4; }
    .section-callout--verdict strong { color: #fff; }

    /* ── FAQ ── */
    .section-callout--faq { background: var(--bg-alt); border: 1px solid var(--border); }
    .section-callout--faq p:first-child { font-weight: 700; margin-bottom: 6px; }

    /* ── Related guides ── */
    .related-guides {
      margin-top: 48px;
      padding: 20px;
      background: var(--bg-alt);
      border: 1px solid var(--border);
      border-radius: 6px;
    }
    .related-label {
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-3);
      margin-bottom: 12px;
    }
    .related-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
    .related-list a {
      color: var(--green);
      text-decoration: none;
      font-size: 14px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .related-list a::before { content: '→'; font-size: 12px; }
    .related-list a:hover { text-decoration: underline; }

    /* ── Footer ── */
    .page-footer {
      max-width: var(--max-w);
      margin: 48px auto 0;
      padding: 28px 20px;
      border-top: 1px solid var(--border);
    }
    .author-block {
      display: flex;
      gap: 16px;
      align-items: flex-start;
      margin-bottom: 20px;
    }
    .author-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: var(--text);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--mono);
      font-size: 14px;
      font-weight: 500;
      flex-shrink: 0;
    }
    .author-info { font-size: 13px; line-height: 1.5; }
    .author-name { font-weight: 700; color: var(--text); display: block; margin-bottom: 2px; }
    .author-bio { color: var(--text-2); }
    .disclosure {
      font-size: 12px;
      color: var(--text-3);
      padding: 14px;
      background: var(--bg-alt);
      border-radius: 4px;
      border: 1px solid var(--border);
    }

    /* ── Mobile ── */
    @media (max-width: 600px) {
      .site-nav { display: none; }
      .article-header h1 { font-size: 1.5rem; }
      article table { font-size: 13px; }
      article th, article td { padding: 8px 10px; }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <a href="/" class="site-logo">Data<span>Tool</span>Index</a>
    <nav class="site-nav">
      <a href="/">All Tools</a>
