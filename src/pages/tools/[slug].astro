    </nav>
  </header>

  <div class="breadcrumb">
    <a href="/">DataToolIndex</a>
    <span>/</span>
    <a href="/">Tools</a>
    <span>/</span>
    {title}
  </div>

  <div class="page">
    <header class="article-header">
      <h1>{title}</h1>
      <div class="article-meta">
        <span class="meta-author">Will Denholm</span>
        <span>·</span>
        <span>Pricing Analyst, 7+ yrs</span>
        <span>·</span>
        <span class="meta-verified">Verified {verifiedDisplay}</span>
      </div>
    </header>

    <article set:html={html} />

    {relatedGuides[slug] && relatedGuides[slug].length > 0 && (
      <aside class="related-guides">
        <div class="related-label">Related comparisons</div>
        <ul class="related-list">
