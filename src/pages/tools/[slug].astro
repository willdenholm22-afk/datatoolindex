---
import fs from 'fs';
import path from 'path';
import { marked } from 'marked';

export async function getStaticPaths() {
  const toolsDir = path.join(process.cwd(), 'src/content/tools');
  const files = fs.readdirSync(toolsDir).filter(f => f.endsWith('.mdx'));

  return files.map(file => ({
    params: { slug: file.replace('.mdx', '') },
    props: { file }
  }));
}

const { file } = Astro.props;

let content = '';
let title = Astro.params.slug;
let description = '';

try {
  const filePath = path.join(process.cwd(), `src/content/tools/${file}`);
  const raw = fs.readFileSync(filePath, 'utf-8');

  // Files have outer frontmatter, then a ```mdx fence containing the real content
  // Strip both frontmatter blocks and the code fence markers
  const innerMatch = raw.match(/```mdx\n([\s\S]*?)```\s*$/);
  if (innerMatch) {
    const inner = innerMatch[1];
    // Strip the inner frontmatter
    const withoutFrontmatter = inner.replace(/^---[\s\S]*?---\n/, '');
    content = withoutFrontmatter;
  } else {
    // Fallback: strip all frontmatter blocks and code fences manually
    const lines = raw.split('\n');
    let frontmatterCount = 0;
    let inFrontmatter = false;
    const contentLines = [];
    for (const line of lines) {
      if (line.trim() === '---') {
        inFrontmatter = !inFrontmatter;
        if (!inFrontmatter) frontmatterCount++;
        continue;
      }
      if (!inFrontmatter && frontmatterCount >= 2 && !line.startsWith('```')) {
        contentLines.push(line);
      }
    }
    content = contentLines.join('\n');
  }

  const titleMatch = content.match(/^#\s+(.+)$/m);
  if (titleMatch) title = titleMatch[1];
  const descMatch = content.match(/^> (.+)$/m);
  if (descMatch) description = descMatch[1];

} catch (e) {
  content = `# Error loading ${Astro.params.slug}\n\n${e}`;
}

const html = marked.parse(content);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} | DataToolIndex</title>
  {description && <meta name="description" content={description} />}
  <style>
    body { font-family: system-ui, sans-serif; max-width: 800px; margin: 0 auto; padding: 20px; line-height: 1.6; color: #333; }
    article h2 { margin-top: 2em; border-bottom: 1px solid #eee; padding-bottom: 0.3em; }
    article table { border-collapse: collapse; width: 100%; margin: 1em 0; }
    article th, article td { border: 1px solid #ddd; padding: 8px 12px; text-align: left; }
    article th { background: #f5f5f5; }
    article code { background: #f5f5f5; padding: 2px 5px; border-radius: 3px; font-size: 0.9em; }
    article pre { background: #f5f5f5; padding: 16px; overflow-x: auto; border-radius: 4px; }
    article a { color: #0066cc; }
  </style>
</head>
<body>
  <header style="margin-bottom: 30px; border-bottom: 1px solid #eee; padding-bottom: 20px;">
    <h1 style="margin: 0; font-size: 20px;"><a href="/" style="text-decoration: none; color: #000;">DataToolIndex</a></h1>
  </header>
  <main>
    <article set:html={html} />
  </main>
  <footer style="margin-top: 60px; padding-top: 20px; border-top: 1px solid #eee; font-size: 13px; color: #666;">
    <p><a href="/methodology">How we review</a> | Will Denholm, pricing analyst</p>
    <p><em>Some links on this page are affiliate links. We may earn a commission at no cost to you. This does not influence our ratings.</em></p>
  </footer>
</body>
</html>
