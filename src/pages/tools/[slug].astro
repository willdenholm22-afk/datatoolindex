    </div>
    <div class="disclosure">
      Some links on this page are affiliate links — we may earn a commission at no cost to you. This does not influence ratings or placement. <a href="/methodology/">Our methodology</a> is public.
    </div>
  </footer>

  <script>
    // Wrap sections after specific h2s in styled callout boxes
    (function() {
      const article = document.querySelector('article');
      if (!article) return;

      function getCalloutClass(text) {
        const t = text.toLowerCase();
        if (t.includes('best for') || t.startsWith('best ')) return 'section-callout--green';
        if (t.includes('not ideal') || t.includes('avoid') || t.includes('limitations')) return 'section-callout--amber';
        if (t === 'verdict') return 'section-callout--verdict';
        if (t === 'faq') return 'section-callout--faq';
        return null;
      }

      const headings = Array.from(article.querySelectorAll('h2'));
      headings.forEach(h2 => {
        const cls = getCalloutClass(h2.textContent.trim());
        if (!cls) return;

        const box = document.createElement('div');
        box.className = 'section-callout ' + cls;

        const siblings = [];
        let next = h2.nextElementSibling;
        while (next && next.tagName !== 'H2') {
          siblings.push(next);
          next = next.nextElementSibling;
        }
        if (siblings.length === 0) return;

        h2.after(box);
        siblings.forEach(s => box.appendChild(s));
      });

      // Style external standalone links (CTA-like) that aren't already marked
      article.querySelectorAll('a[href^="http"]').forEach(a => {
        if (!a.classList.contains('cta-link') && !a.closest('table')) {
          // If link is the only non-whitespace content in its paragraph, make it a CTA
          const parent = a.parentElement;
          if (parent && parent.tagName === 'P' && parent.textContent.trim() === a.textContent.trim()) {
            a.classList.add('cta-link');
          }
        }
      });
    })();
  </script>
</body>
</html>
