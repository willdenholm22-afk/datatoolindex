---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>DataToolIndex — Expert B2B Data Tool Comparisons</title>
  <meta name="description" content="Practitioner-grade reviews of ETL, BI, pricing, and warehouse tools. Written by a B2B analyst who uses these in production. Verified pricing, honest verdicts." />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: system-ui, -apple-system, sans-serif; max-width: 960px; margin: 0 auto; padding: 24px 20px; line-height: 1.6; color: #1a1a1a; }
    header { border-bottom: 2px solid #111; padding-bottom: 20px; margin-bottom: 40px; }
    header h1 { margin: 0 0 8px; font-size: 28px; letter-spacing: -0.5px; }
    header p { margin: 0; color: #555; font-size: 15px; }
    h2 { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #888; border-bottom: 1px solid #eee; padding-bottom: 6px; margin: 36px 0 14px; }
    .tool-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 10px; }
    .tool-card { border: 1px solid #e5e5e5; border-radius: 6px; padding: 12px 14px; text-decoration: none; color: inherit; display: block; transition: border-color 0.15s; }
    .tool-card:hover { border-color: #111; }
    .tool-card .name { font-weight: 600; font-size: 15px; }
    .tool-card .cat { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: #888; margin-bottom: 2px; }
    .tool-card .tagline { font-size: 13px; color: #555; margin-top: 3px; }
    .use-case-list { list-style: none; padding: 0; margin: 0; }
    .use-case-list li { border-bottom: 1px solid #f0f0f0; }
    .use-case-list li:last-child { border-bottom: none; }
    .use-case-list a { display: block; padding: 10px 0; text-decoration: none; color: #0066cc; font-size: 15px; }
    .use-case-list a:hover { color: #004499; }
    footer { margin-top: 60px; padding-top: 20px; border-top: 1px solid #eee; font-size: 13px; color: #888; }
    footer a { color: #888; }
  </style>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "DataToolIndex",
    "url": "https://datatoolindex.com",
    "description": "Expert-reviewed comparisons of B2B data tools, pricing software, ETL pipelines, and BI platforms.",
    "author": {
      "@type": "Person",
      "name": "Will Denholm",
      "jobTitle": "B2B Pricing Analyst"
    }
  }
  </script>
</head>
<body>
  <header>
    <h1>DataToolIndex</h1>
    <p>Practitioner reviews of B2B data tools — ETL, BI, pricing software, warehouses, and orchestration. Written by Will Denholm, pricing analyst. Pricing verified against vendor sources.</p>
  </header>

  <section>
    <h2>Use-Case Comparisons</h2>
    <ul class="use-case-list">
      {useCases.map(uc => (
        <li><a href={`/use-cases/${uc.slug}/`}>{uc.title}</a></li>
      ))}
    </ul>
  </section>

  {categories.map(cat => (
    <section>
      <h2>{cat}</h2>
      <div class="tool-grid">
        {tools.filter(t => t.category === cat).map(tool => (
          <a href={`/tools/${tool.slug}/`} class="tool-card">
            <div class="cat">{tool.category}</div>
            <div class="name">{tool.name}</div>
            <div class="tagline">{tool.tagline}</div>
          </a>
        ))}
      </div>
    </section>
  ))}

  <footer>
    <p><a href="/methodology/">How we review</a> · Will Denholm, B2B pricing analyst · <a href="/llms.txt">llms.txt</a></p>
    <p>Some links on this site are affiliate links. We may earn a commission at no cost to you. This does not influence our ratings.</p>
  </footer>
</body>
</html>
